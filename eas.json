        "EXPO_PUBLIC_INGEST_URL": "http://spaceguard-rm560512.eastus2.azurecontainer.io:8083/importar"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "http://spaceguard-rm560512.eastus2.azurecontainer.io:8080",
        "EXPO_PUBLIC_INGEST_URL": "http://spaceguard-rm560512.eastus2.azurecontainer.io:8083/importar"
